# Scout secrets template
# 使用：cp .env.example .env 然后填入真实值；.env 不会被 commit。

# QQ 开放平台 C2C 主动推送（qq_push.enabled=true 时必填）
QQ_BOT_APP_ID=your_app_id_here
QQ_BOT_SECRET=your_client_secret_here
QQ_USER_OPENID=your_openid_here

# OpenClaw Gateway Bearer（可选；test_qq_push.py 路径 A 用）
QQ_GATEWAY_TOKEN=your_gateway_token_here
